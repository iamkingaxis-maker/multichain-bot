# Chart CNN — trained weights and dataset (large binaries, not committed)
# EXCEPT chart_cnn_v1.pt and chart_encoder_v1.pt which are force-tracked
# so Railway picks them up (railway up respects .gitignore even for tracked files).
models/*.pt
!models/chart_cnn_v1.pt
!models/chart_encoder_v1.pt
models/*.pkl
!models/fusion_constrained_v1.pkl
!models/fusion_meta_v1.pkl
.cnn_dataset/

# --- 2026-05-29 bulk scratch sweep (workspace had 1461 untracked artifacts) ---
# Prefix-by-prefix enumeration above didn't scale. Broad root-level rules.
# Tracked files (config.json, main.py, committed reports) are unaffected —
# gitignore never un-tracks an already-committed file.
# Root-level dotfile scratch by extension:
/.*.json
/.*.txt
/.*.py
/.*.bin
/.*.pkl
/.*.jsonl
/.*.csv
/.*.html
# Root-level plain scratch (chart screenshots, dumps, temp logs):
/*.png
/*.jpeg
/*.jpg
/*.tmp
/trades_*.json
/all_trades.json
/all_logs*.tmp
# Scratch / cache / mining output directories:
mining_*/
universe_mine/
universe_recorder/
gt_cache_exh/
deep_mine_cache/
perf_diff_drafts/
chart_analysis*/
.chart_analysis*/
watch7h/
.watch7h/
_archive/
# dotted scratch dirs + remaining scratch extensions:
.deep_mine_cache/
.gt_cache_exh/
.mining_*/
.universe_mine/
.universe_recorder/
.perf_diff_drafts/
/.*.md
/.*.pkl
/.*.bat
/.*.ps1
/.*.sh
/.*.toml
# root data scratch (config.json is the only legit tracked root json):
/*.json
!/config.json
/*.pkl
scripts/_*.pkl
# cloudflare worker build/test caches (source IS committed):
cloudflare_worker/.wrangler/
cloudflare_worker/.pytest_cache/

# Analysis archive (sprint scripts + data dumps live on disk, not in git;
# scripts already tracked before the 2026-06-10 sweep stay tracked)
analysis/
!analysis/2026-06/MANIFEST.md

# Root-level one-off outputs — archive scripts under analysis/<sprint>/ instead
/_*.err
/_*.out
/_*.npy
/*.pkl

# RPC key (free tier) — never commit
alchemy_key.txt

# RH probe hot-wallet key (scripts/rh_make_wallet.py) — NEVER commit
rh_wallet_key.txt

# 2026-07-11: keep RH decode reports in git, exclude the 628MB raw dumps
scratchpad/rh_history/*.jsonl
scratchpad/rh_history/*.jsonl.gz
scratchpad/rh_history/hist_*
scratchpad/rug_forensics/*.jsonl
